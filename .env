# ===============================
# GenAI ETL Agent Configuration
# ===============================

# Google Gemini API Key
GEMINI_API_KEY=AIzaSyD2DyCLFzZsq9BnaOjNeJFYb0tXtLPqsQg

# Model (Chosen Model)
# Use: gemini-1.5-pro (recommended for reasoning-heavy ETL agent)
GEMINI_MODEL=gemini-2.5-flash

# Optional Settings

# Max tokens for response
MAX_OUTPUT_TOKENS=2048

# Temperature (lower = more deterministic)
TEMPERATURE=0.2

# Top-p sampling
TOP_P=0.9

# ETL Agent Behavior Flags

ENABLE_SCHEMA_INFERENCE=true
ENABLE_TRANSFORMATION_PLANNING=true
ENABLE_VALIDATION=true

# Debug Mode
DEBUG=true